set(LUAU_STATIC_CRT OFF CACHE BOOL "Use static CRT for Luau" FORCE)
set(LUAU_ROOT ${SINEN_SOURCE_DIR}/libs/luau)

set(CPP_DAP_ROOT ${SINEN_SOURCE_DIR}/libs/cppdap)
