option(BUILD_SHARED_LIBS OFF)
set(SDL_SHARED ${BUILD_SHARED_LIBS})
set(SDL_STATIC NOT ${BUILD_SHARED_LIBS})
set(SDL3_INCLUDE_PATHS ${SINEN_SOURCE_DIR}/libs/SDL/include)
set(ASSIMP_BUILD_ALL_EXPORTERS_BY_DEFAULT OFF)
if(EMSCRIPTEN)
  set(ASSIMP_BUILD_ZLIB ON CACHE BOOL "Build assimp's bundled zlib" FORCE)
endif()

if(WIN32)
  set(SLANG_EMBED_CORE_MODULE_SOURCE OFF)
  set(SLANG_ENABLE_EXAMPLES OFF)
  set(SLANG_ENABLE_TESTS OFF)
  set(SLANG_ENABLE_REPLAYER OFF)
  set(SLANG_ENABLE_SLANGC OFF)
  set(SLANG_ENABLE_SLANGD OFF)
  set(SLANG_ENABLE_SLANGI OFF)
  set(SLANG_ENABLE_GFX OFF)
  set(SLANG_RHI_ENABLE OFF)
  set(SLANG_RHI_ENABLE_OPTIX OFF)
  set(SLANG_RHI_ENABLE_CUDA OFF)
  set(SLANG_RHI_ENABLE_NVAPI OFF)
  set(SLANG_RHI_ENABLE_CPU OFF)
  set(SLANG_RHI_ENABLE_D3D11 OFF)
  set(SLANG_RHI_ENABLE_D3D12 OFF)
  set(SLANG_RHI_ENABLE_VULKAN OFF)
  set(SLANG_RHI_ENABLE_WGPU OFF)
  set(SLANG_RHI_ENABLE_AGILITY_SDK OFF)
  set(SLANG_LIB_TYPE STATIC)
endif()

set(ENABLE_ALL_WARNINGS OFF)

set(USE_STATIC_MSVC_RUNTIME_LIBRARY OFF)

set(WEBGPU_LINK_TYPE SHARED CACHE STRING "Native WebGPU link type")

set(MSDFGEN_CORE_ONLY ON)
set(MSDFGEN_BUILD_STANDALONE OFF)
set(MSDFGEN_USE_VCPKG OFF)
set(MSDFGEN_USE_CPP11 ON)
set(MSDFGEN_USE_SKIA OFF)
set(MSDFGEN_DYNAMIC_RUNTIME ON)

set(LUAU_BUILD_TESTS OFF CACHE BOOL "Build Luau tests" FORCE)
set(LUAU_BUILD_CLI OFF CACHE BOOL "Build Luau CLI tools" FORCE)
